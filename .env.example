# --- Ollama (recommended: use the model you pulled with ollama pull) ---
# Model name (e.g. qwen3.5, qwen2.5, llama3.2)
OLLAMA_MODEL=qwen3.5
# Only if Ollama runs on another host/port
# OLLAMA_BASE_URL=http://localhost:11434
# Start Ollama server automatically if not running (set to 0 to disable)
OLLAMA_AUTO_START=1

# --- Optional: GGUF file instead of Ollama ---
# QWEN_MODEL_PATH=
# LLAMA_MODEL_PATH=
